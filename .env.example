# Copiar a .env y rellenar. El .env real NUNCA se commitea (ver .gitignore / Gitleaks).
POSTGRES_DB=habits
POSTGRES_USER=habits
POSTGRES_PASSWORD=cambia-esto-en-local
POSTGRES_PORT=5432
APP_PORT=8080

# Clave HMAC del firmado JWT. Minimo 32 bytes. Generar con:
#   openssl rand -base64 48
HABITS_SECURITY_JWT_SECRET=
